{
  "version": 2,
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "framework": "create-react-app",
      "envDirectory": "frontend"
    },
    "backend": {
      "entrypoint": "backend/api",
      "framework": "@vercel/node",
      "envDirectory": "backend"
    }
  },
  "buildCommand": "cd frontend && npm run build && cd ../backend && npm install",
  "installCommand": "npm install --workspaces"
}
